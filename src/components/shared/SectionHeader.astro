---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  dark?: boolean;
  center?: boolean;
}

const { eyebrow, title, subtitle, dark = false, center = false } = Astro.props;

const titleColor = dark ? 'text-on-dark' : 'text-ink';
const subtitleColor = dark ? 'text-on-dark/70' : 'text-body';
const eyebrowColor = dark ? 'text-primary' : 'text-primary';
const alignClass = center ? 'text-center' : '';
---

<div class={`mb-12 ${alignClass}`}>
  {eyebrow && (
    <p class={`text-xs font-semibold uppercase tracking-widest ${eyebrowColor} mb-3`}>
      {eyebrow}
    </p>
  )}
  <h2 class={`text-2xl md:text-4xl font-bold leading-tight ${titleColor}`}>
    {title}
  </h2>
  {subtitle && (
    <p class={`mt-4 text-base md:text-lg ${subtitleColor} max-w-2xl ${center ? 'mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
</div>
