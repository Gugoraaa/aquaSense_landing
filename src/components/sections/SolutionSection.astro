---
import SectionHeader from '../shared/SectionHeader.astro';

const cards = [
  {
    title: 'Monitoreo en tiempo real',
    description: 'Visualiza pH, cloro, turbidez, presión, caudal y más en tiempo real.',
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    title: 'Alertas inteligentes',
    description: 'Notificaciones automáticas cuando un parámetro sale de rango definido.',
    icon: `<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>`,
  },
  {
    title: 'Dosificación recomendada',
    description: 'Calcula ajustes químicos según caudal y calidad del agua actual.',
    icon: `<path d="M14 2v6l3 4.67A2 2 0 0 1 15.33 16H8.67A2 2 0 0 1 7 12.67L10 8V2"/><line x1="8.5" y1="2" x2="15.5" y2="2"/>`,
  },
  {
    title: 'Reportes automáticos',
    description: 'Genera reportes operativos y de cumplimiento en PDF o Excel automáticamente.',
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>`,
  },
  {
    title: 'Históricos y trazabilidad',
    description: 'Consulta tendencias, eventos y acciones por planta o periodo.',
    icon: `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  },
  {
    title: 'Multi-planta',
    description: 'Supervisa varias instalaciones desde una sola vista centralizada.',
    icon: `<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>`,
  },
];
---

<section id="servicios" class="bg-surface py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <SectionHeader
      eyebrow="Solución"
      title="Una sola plataforma para monitorear, alertar y optimizar."
      center
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map((card) => (
        <div class="bg-surface border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-lg transition-all duration-200 cursor-default">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary mb-4"
            set:html={card.icon}
          />
          <h3 class="font-bold text-ink mb-2">{card.title}</h3>
          <p class="text-body text-sm leading-relaxed">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
