---
import SectionHeader from '../shared/SectionHeader.astro';
import { LuTriangleAlert, LuBellRing, LuDroplets, LuFlaskConical, LuWrench, LuClock, LuFileOutput } from 'react-icons/lu';

const workflows = [
  {
    TriggerIcon: LuTriangleAlert,
    trigger: 'Turbidez fuera de rango',
    ActionIcon: LuBellRing,
    action: 'Envía alerta al operador por WhatsApp',
  },
  {
    TriggerIcon: LuDroplets,
    trigger: 'Cloro libre bajo',
    ActionIcon: LuFlaskConical,
    action: 'Recomienda ajuste de dosificación',
  },
  {
    TriggerIcon: LuTriangleAlert,
    trigger: 'Presión diferencial elevada',
    ActionIcon: LuWrench,
    action: 'Sugiere mantenimiento del filtro',
  },
  {
    TriggerIcon: LuTriangleAlert,
    trigger: 'Sensor sin señal',
    ActionIcon: LuBellRing,
    action: 'Notifica al equipo técnico',
  },
  {
    TriggerIcon: LuClock,
    trigger: 'Fin de turno',
    ActionIcon: LuFileOutput,
    action: 'Genera reporte automático',
  },
];
---

<section id="automatizaciones" class="bg-canvas py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <SectionHeader
      eyebrow="Automatización"
      title="De datos en tiempo real a acciones automáticas."
      subtitle="Configura reglas simples para que AquaSense actúe cuando algo cambia en tu planta."
      center
    />

    <div class="flex flex-col gap-4 max-w-3xl mx-auto">
      {workflows.map(({ TriggerIcon, trigger, ActionIcon, action }) => (
        <div class="flex items-center gap-0 rounded-xl overflow-hidden">
          <!-- Trigger -->
          <div class="flex-1 bg-surface border border-border px-5 py-4 flex items-center gap-3">
            <TriggerIcon size={20} className="text-body flex-shrink-0" aria-hidden="true" />
            <span class="text-sm font-medium text-ink">{trigger}</span>
          </div>

          <!-- Arrow -->
          <div class="px-3 py-4 bg-surface border-y border-border text-muted font-bold text-xl select-none">
            →
          </div>

          <!-- Action -->
          <div class="flex-1 bg-primary/10 border border-primary/20 text-ink px-5 py-4 flex items-center gap-3">
            <ActionIcon size={20} className="text-primary flex-shrink-0" aria-hidden="true" />
            <span class="text-sm font-medium">{action}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
