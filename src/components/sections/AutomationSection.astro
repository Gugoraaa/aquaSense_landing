---
import SectionHeader from '../shared/SectionHeader.astro';

const workflows = [
  {
    triggerIcon: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
    trigger: 'Turbidez fuera de rango',
    actionIcon: `<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M21 5.5a10.19 10.19 0 0 0-2.82-3.51"/><path d="M3 5.5A10.19 10.19 0 0 1 5.82 2"/>`,
    action: 'Envía alerta al operador por WhatsApp',
  },
  {
    triggerIcon: `<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>`,
    trigger: 'Cloro libre bajo',
    actionIcon: `<path d="M14 2v6l3 4.67A2 2 0 0 1 15.33 16H8.67A2 2 0 0 1 7 12.67L10 8V2"/><line x1="8.5" y1="2" x2="15.5" y2="2"/>`,
    action: 'Recomienda ajuste de dosificación',
  },
  {
    triggerIcon: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
    trigger: 'Presión diferencial elevada',
    actionIcon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
    action: 'Sugiere mantenimiento del filtro',
  },
  {
    triggerIcon: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
    trigger: 'Sensor sin señal',
    actionIcon: `<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M21 5.5a10.19 10.19 0 0 0-2.82-3.51"/><path d="M3 5.5A10.19 10.19 0 0 1 5.82 2"/>`,
    action: 'Notifica al equipo técnico',
  },
  {
    triggerIcon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
    trigger: 'Fin de turno',
    actionIcon: `<path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><polyline points="14 2 14 8 20 8"/><path d="M2 15h10"/><path d="m9 18 3-3-3-3"/>`,
    action: 'Genera reporte automático',
  },
];
---

<section id="automatizaciones" class="bg-surface py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <SectionHeader
      eyebrow="Automatización"
      title="De datos en tiempo real a acciones automáticas."
      subtitle="Configura reglas simples para que AquaSense actúe cuando algo cambia en tu planta."
      center
    />

    <div class="flex flex-col gap-4 max-w-3xl mx-auto">
      {workflows.map((wf) => (
        <div class="flex items-center gap-0 rounded-xl overflow-hidden">
          <!-- Trigger -->
          <div class="flex-1 bg-[#EEF6F4] px-5 py-4 flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-body flex-shrink-0"
              set:html={wf.triggerIcon}
            />
            <span class="text-sm font-medium text-ink">{wf.trigger}</span>
          </div>

          <!-- Arrow -->
          <div class="px-3 py-4 bg-[#EEF6F4] text-muted font-bold text-xl select-none">
            →
          </div>

          <!-- Action -->
          <div class="flex-1 bg-[#071B20] text-[#F7FAFA] px-5 py-4 flex items-center gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary flex-shrink-0"
              set:html={wf.actionIcon}
            />
            <span class="text-sm font-medium">{wf.action}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
