---
import SectionHeader from '../shared/SectionHeader.astro';

const cards = [
  {
    title: 'Plantas de tratamiento municipal',
    icon: `<rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/>`,
  },
  {
    title: 'Industria de alimentos',
    icon: `<path d="m16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8"/><path d="M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7"/><path d="m2 22 3-3"/>`,
  },
  {
    title: 'Bebidas y embotelladoras',
    icon: `<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>`,
  },
  {
    title: 'Parques industriales',
    icon: `<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/>`,
  },
  {
    title: 'Tratamiento de agua residual',
    icon: `<path d="M7 19H4.815a1.83 1.83 0 0 1-1.57-2.163l2.9-12.2a2 2 0 0 1 1.929-1.572H20a2 2 0 0 1 1.929 2.572l-1.636 5.044"/><path d="m21 13-3-3 3-3"/><path d="M9 21 6 18l3-3"/><path d="M11 21 8 18"/><path d="m14 21 3-3-3-3"/>`,
  },
  {
    title: 'Múltiples plantas o ubicaciones',
    icon: `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
  },
];
---

<section id="funcionalidades" class="bg-canvas py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <SectionHeader
      eyebrow="Casos de uso"
      title="Diseñado para operaciones donde la calidad del agua no puede esperar."
      center
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map((card) => (
        <div class="bg-surface border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-md transition-all duration-200">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary mb-4"
            set:html={card.icon}
          />
          <h3 class="font-bold text-ink">{card.title}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
