---
import SectionHeader from '../shared/SectionHeader.astro';
import { LuBuilding, LuUtensilsCrossed, LuDroplets, LuFactory, LuRecycle, LuMapPin } from 'react-icons/lu';

const cards = [
  {
    title: 'Plantas de tratamiento municipal',
    Icon: LuBuilding,
  },
  {
    title: 'Industria de alimentos',
    Icon: LuUtensilsCrossed,
  },
  {
    title: 'Bebidas y embotelladoras',
    Icon: LuDroplets,
  },
  {
    title: 'Parques industriales',
    Icon: LuFactory,
  },
  {
    title: 'Tratamiento de agua residual',
    Icon: LuRecycle,
  },
  {
    title: 'Múltiples plantas o ubicaciones',
    Icon: LuMapPin,
  },
];
---

<section id="funcionalidades" class="bg-canvas py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <SectionHeader
      eyebrow="Casos de uso"
      title="Diseñado para operaciones donde la calidad del agua no puede esperar."
      center
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map(({ Icon, title }) => (
        <div class="bg-surface border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-md transition-all duration-200">
          <Icon size={32} className="text-primary mb-4" aria-hidden="true" />
          <h3 class="font-bold text-ink">{title}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
