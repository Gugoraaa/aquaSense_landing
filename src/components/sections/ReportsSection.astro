---
import SectionHeader from '../shared/SectionHeader.astro';
import { LuCheck } from 'react-icons/lu';

const checkItems = [
  'Reportes diarios, semanales y mensuales',
  'Historial de alertas con resolución',
  'Registro de acciones por turno',
  'Tendencias por parámetro y planta',
  'Exportación PDF y Excel',
  'Evidencia para auditorías internas',
];

const reportRows = [
  { label: 'pH promedio', value: '7.1' },
  { label: 'Turbidez máxima', value: '1.2 NTU' },
  { label: 'Eventos críticos', value: '2' },
  { label: 'Acciones tomadas', value: '2' },
  { label: 'Consumo químico', value: '↓ 18%' },
];

---

<section class="bg-canvas py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Left: content -->
      <div>
        <SectionHeader
          eyebrow="Reportes"
          title="Reportes listos para operación, auditoría y cumplimiento."
        />

        <ul class="flex flex-col gap-4">
          {checkItems.map((item) => (
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <LuCheck size={14} strokeWidth={3} className="text-primary" aria-hidden="true" />
              </span>
              <span class="text-body text-sm">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: report card mockup -->
      <div class="border border-border shadow-lg rounded-2xl overflow-hidden">
        <!-- Header -->
        <div class="bg-dark text-on-dark px-6 py-4">
          <p class="font-semibold text-sm">Reporte mensual · Planta Norte · Mayo 2026</p>
        </div>

        <!-- Body -->
        <div class="bg-surface p-6 flex flex-col gap-4">
          {reportRows.map((row) => (
            <div class="flex items-center justify-between py-2 border-b border-border last:border-0">
              <span class="text-muted text-sm">{row.label}</span>
              <span class="text-ink font-semibold text-sm">{row.value}</span>
            </div>
          ))}
        </div>

        <!-- Footer -->
        <div class="bg-surface px-6 pb-6 flex gap-3 flex-wrap">
          <button class="inline-flex items-center justify-center px-4 py-2 border border-primary text-primary text-sm font-semibold rounded-xl hover:bg-primary/5 transition-colors duration-200">
            Descargar PDF
          </button>
          <button class="inline-flex items-center justify-center px-4 py-2 border border-border text-ink text-sm font-semibold rounded-xl hover:bg-surface-soft transition-colors duration-200">
            Exportar Excel
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
