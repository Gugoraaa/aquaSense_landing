---
import SectionHeader from '../shared/SectionHeader.astro';

const cards = [
  {
    title: 'Monitoreo manual',
    description: 'Parámetros críticos revisados manualmente, sin alertas automáticas.',
    icon: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
  },
  {
    title: 'Alertas tardías',
    description: 'Las notificaciones llegan tarde o están dispersas en múltiples sistemas.',
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    title: 'Reportes en Excel',
    description: 'Los reportes se elaboran en hojas de cálculo, consumiendo tiempo del equipo.',
    icon: `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 9v9"/><path d="M15 9v9"/>`,
  },
  {
    title: 'Dosificación imprecisa',
    description: 'La dosificación química depende de estimaciones, no de datos en tiempo real.',
    icon: `<path d="M14 2v6l3 4.67A2 2 0 0 1 15.33 16H8.67A2 2 0 0 1 7 12.67L10 8V2"/><line x1="8.5" y1="2" x2="15.5" y2="2"/>`,
  },
  {
    title: 'Sin trazabilidad',
    description: 'No hay historial por turno, planta o evento para auditorías o mejoras.',
    icon: `<path d="M12.83 2h-1.66L9 7H5l-1 2 4 4-1 3 3 2 3-2-1-3 4-4-1-2h-4z"/><path d="M9 19H5l-1 2"/><path d="M15 19h4l1 2"/>`,
  },
];
---

<section class="bg-canvas py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <SectionHeader
      eyebrow="El problema"
      title="Las plantas generan datos todo el tiempo, pero las decisiones llegan tarde."
      center
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map((card) => (
        <div class="bg-surface border border-border rounded-2xl p-6">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary mb-4"
            set:html={card.icon}
          />
          <h3 class="font-bold text-ink mb-2">{card.title}</h3>
          <p class="text-body text-sm leading-relaxed">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
