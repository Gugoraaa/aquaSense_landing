---
import { LuCpu, LuRouter, LuCloudCog, LuMonitorSmartphone } from 'react-icons/lu';

const steps = [
  {
    num: '01',
    title: 'Sensores y PLCs existentes',
    description: 'Compatible con equipos de campo y protocolos industriales. Sin reemplazar nada.',
    tags: ['Modbus', 'OPC-UA', 'MQTT'],
    Icon: LuCpu,
  },
  {
    num: '02',
    title: 'Gateway de conectividad',
    description: 'Centraliza datos sin interrumpir la operación ni requerir obra civil.',
    tags: ['Sin obra', 'Plug & play'],
    Icon: LuRouter,
  },
  {
    num: '03',
    title: 'AquaSense Cloud',
    description: 'Procesamiento en tiempo real, históricos ilimitados y detección de anomalías con IA.',
    tags: ['IA', '99.9% uptime'],
    Icon: LuCloudCog,
  },
  {
    num: '04',
    title: 'Dashboard y acciones',
    description: 'Visualiza, recibe alertas y genera reportes desde cualquier dispositivo.',
    tags: ['Web', 'Móvil', 'WhatsApp'],
    Icon: LuMonitorSmartphone,
  },
];
---

<section id="como-funciona" class="process-section relative overflow-hidden bg-canvas py-24 md:py-28">
  <div class="process-wave process-wave-left" aria-hidden="true"></div>
  <div class="process-wave process-wave-right" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-[1220px] px-6">
    <div class="mx-auto max-w-[940px] text-center">
      <p class="mb-4 text-xs font-bold uppercase tracking-[0.32em] text-primary">
        Proceso
      </p>
      <h2 class="text-[clamp(2rem,4vw,2.7rem)] font-extrabold leading-[1.08] tracking-normal text-ink">
        Conecta tu infraestructura actual sin reemplazarla.
      </h2>
    </div>

    <div class="process-flow relative mt-16">
      <div class="process-rail hidden lg:block" aria-hidden="true">
        <span class="process-rail-line"></span>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
        {steps.map(({ Icon, num, title, description, tags }) => (
          <article class="process-step relative pt-20">
            <div class="process-marker absolute left-1/2 top-0 flex h-14 w-14 -translate-x-1/2 items-center justify-center rounded-full text-lg font-extrabold text-white">
              {num}
            </div>

            <div class="process-card flex h-full min-h-[310px] flex-col rounded-lg border border-border bg-surface px-6 py-7 shadow-[0_22px_50px_-32px_rgba(0,0,0,0.8)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_28px_58px_-32px_rgba(0,0,0,0.9)]">
              <Icon size={58} strokeWidth={1.7} className="mb-8 text-primary" aria-hidden="true" />

              <h3 class="mb-3 text-base font-extrabold leading-tight text-ink">
                {title}
              </h3>
              <p class="mb-6 text-sm leading-[1.65] text-body">
                {description}
              </p>

              <div class="mt-auto flex flex-wrap gap-2.5">
                {tags.map((tag) => (
                  <span class="rounded-full bg-primary/10 px-3 py-1.5 text-xs font-semibold leading-none text-primary">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .process-section {
    isolation: isolate;
  }

  .process-flow {
    --marker-center: 1.75rem;
  }

  .process-rail {
    position: absolute;
    left: 0;
    right: 0;
    top: var(--marker-center);
    height: 2px;
    pointer-events: none;
  }

  .process-rail-line {
    position: absolute;
    left: calc(12.5% + 1rem);
    right: calc(12.5% + 1rem);
    height: 2px;
    background:
      linear-gradient(90deg, rgba(39, 121, 242, 0.74), rgba(39, 121, 242, 0.82) 50%, rgba(39, 121, 242, 0.74));
    box-shadow:
      0 0 0 1px rgba(79, 155, 232, 0.18),
      0 0 16px rgba(79, 155, 232, 0.45),
      0 0 34px rgba(79, 155, 232, 0.22);
  }

  .process-rail-line::after {
    content: "";
    position: absolute;
    inset: -1px 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(120, 180, 255, 0.45), transparent);
  }

  .process-marker {
    background: linear-gradient(180deg, #5aa0ee 0%, #2f72c9 100%);
    border: 5px solid #0f141c;
    box-shadow:
      0 0 0 6px rgba(79, 155, 232, 0.16),
      0 12px 28px -14px rgba(20, 90, 190, 0.9),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
    z-index: 2;
  }

  .process-marker::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -0.72rem;
    width: 0.52rem;
    height: 0.52rem;
    border-radius: 0.1rem;
    background: #65a6ff;
    border: 2px solid #0f141c;
    transform: translateX(-50%) rotate(45deg);
    box-shadow: 0 4px 10px rgba(39, 121, 242, 0.3);
  }

  .process-card {
    position: relative;
    z-index: 1;
  }

  .process-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .process-wave {
    position: absolute;
    z-index: -1;
    width: min(34rem, 46vw);
    height: 12rem;
    opacity: 0.5;
    background-image: url("data:image/svg+xml,%3Csvg width='560' height='190' viewBox='0 0 560 190' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%232779f2' stroke-opacity='.16' stroke-width='1' stroke-dasharray='3 6'%3E%3Cpath d='M0 45c56 0 56 32 112 32s56-32 112-32 56 32 112 32 56-32 112-32 56 32 112 32'/%3E%3Cpath d='M0 68c56 0 56 32 112 32s56-32 112-32 56 32 112 32 56-32 112-32 56 32 112 32'/%3E%3Cpath d='M0 91c56 0 56 32 112 32s56-32 112-32 56 32 112 32 56-32 112-32 56 32 112 32'/%3E%3Cpath d='M0 114c56 0 56 32 112 32s56-32 112-32 56 32 112 32 56-32 112-32 56 32 112 32'/%3E%3Cpath d='M0 137c56 0 56 32 112 32s56-32 112-32 56 32 112 32 56-32 112-32 56 32 112 32'/%3E%3C/g%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-size: contain;
    pointer-events: none;
  }

  .process-wave-left {
    left: -9rem;
    bottom: 1.5rem;
  }

  .process-wave-right {
    right: -3rem;
    bottom: -1.4rem;
  }

  @media (max-width: 1023px) {
    .process-step {
      padding-top: 4.75rem;
    }
  }

  @media (max-width: 767px) {
    .process-section {
      padding-top: 5rem;
      padding-bottom: 5.5rem;
    }

    .process-wave {
      display: none;
    }

    .process-card {
      min-height: auto;
    }
  }
</style>
