---
import HeroDashboard from './HeroDashboard.tsx';
import HeroIntro from './HeroIntro.tsx';
import HeroFloatingCards from './HeroFloatingCards.tsx';

// Mismos datos que las floating cards; versión inline para tablet/mobile,
// donde las cards flotantes se ocultan para evitar saturación.
const stats = [
  { value: '24/7', label: 'Monitoreo continuo' },
  { value: '<30 s', label: 'Tiempo de respuesta' },
  { value: '99.9%', label: 'Disponibilidad objetivo' },
  { value: '+18%', label: 'Ahorro en químicos' },
];
---

<section class="hero relative overflow-hidden bg-canvas pt-32 pb-20 md:pt-40 md:pb-28">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-arc" aria-hidden="true"></div>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-[1200px] px-6">
    <!-- Composición superior: contenido centrado + floating cards alrededor -->
    <div class="relative">
      <HeroFloatingCards client:visible />
      <HeroIntro client:load />
    </div>

    <!-- Stats inline para tablet/mobile (las floating cards solo se ven en xl) -->
    <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-4 xl:hidden">
      {
        stats.map((stat) => (
          <div class="rounded-2xl border border-border bg-surface/70 p-4 text-center">
            <p class="font-display text-2xl font-extrabold tracking-[-0.02em] text-ink">
              {stat.value}
            </p>
            <p class="mt-1 text-xs text-muted">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <!-- Dashboard emergiendo en la parte inferior -->
    <div class="relative z-10 mx-auto mt-12 max-w-[940px] md:mt-2">
      <HeroDashboard client:load />
    </div>
  </div>
</section>

<style>
  /* Grid sutil, desvanecido hacia los bordes */
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 64px 64px;
    -webkit-mask-image: radial-gradient(ellipse 78% 62% at 50% 26%, #000 0%, transparent 76%);
    mask-image: radial-gradient(ellipse 78% 62% at 50% 26%, #000 0%, transparent 76%);
  }

  /* Arcos suaves tipo SaaS premium, muy discretos */
  .hero-arc {
    position: absolute;
    left: 50%;
    top: 30%;
    z-index: 0;
    width: 1180px;
    height: 1180px;
    transform: translateX(-50%);
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow: 0 0 0 60px rgba(255, 255, 255, 0.012);
    -webkit-mask-image: radial-gradient(circle at 50% 0%, #000 0%, transparent 52%);
    mask-image: radial-gradient(circle at 50% 0%, #000 0%, transparent 52%);
  }

  /* Glow azul muy sutil en la parte superior */
  .hero-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 58% 38% at 50% 0%, rgba(79, 155, 232, 0.10), transparent 62%);
  }
</style>
