---
import HeroDashboard from './HeroDashboard.tsx';
import HeroIntro from './HeroIntro.tsx';
import HeroStats from './HeroStats.tsx';
---

<section
  class="py-24 md:py-32"
  style="background: radial-gradient(circle at 70% 20%, rgba(59,130,196,0.18), transparent 35%), radial-gradient(circle at 20% 80%, rgba(34,197,94,0.10), transparent 30%), #F7F8F4;"
>
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Main grid -->
    <div class="grid md:grid-cols-[55fr_45fr] gap-12 items-center">
      <HeroIntro client:load />

      <!-- Right column -->
      <div class="min-h-[400px] flex items-center">
        <HeroDashboard client:load />
      </div>
    </div>

    <HeroStats client:visible />
  </div>
</section>
